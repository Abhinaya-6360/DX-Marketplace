    "usage": {
      "principle": "Patterns add visual rhythm without adding chrome. Use sparingly.",
      "rules": [
        { "type": "do",   "text": "Use one pattern family per page section. Mixing dot + arrow + division in the same view creates noise." },
        { "type": "do",   "text": "Match pattern tone to surface tone — light variants on light surfaces, dark variants on dark surfaces." },
        { "type": "do",   "text": "Tile dot patterns as backgrounds. Use arrow / division patterns as discrete accents (one to three placements per section)." },
        { "type": "dont", "text": "Stack patterns over CTAs, body text, or any interactive surface. Patterns are decorative — they should never compete with content." },
        { "type": "dont", "text": "Recolour patterns outside the recommended fill tokens. Patterns inherit their colour from the design system, not from the page." },
        { "type": "dont", "text": "Scale patterns below 192px tile size — the geometry breaks down. Tile at native 256px or larger." }
      ]
    },
    "exportInstructions": {
      "format": "SVG (preferred) or PNG @2x (fallback)",
      "size": "256×256px native",
      "fillStrategy": "Use currentColor in SVG so the pattern can be recoloured via CSS color property",
      "destination": "design-system/foundations/patterns/{family}/{variant}.svg",
      "todo": "Export all 13 variants from Figma at node 7215:556 and place them in the patterns/ directory next to this JSON file."
